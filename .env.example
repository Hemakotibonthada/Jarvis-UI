# ─── J.A.R.V.I.S. Environment Configuration ──────────────────
# Copy this file to .env and fill in your values

# OpenAI (Required)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Email (Optional — for email features)
JARVIS_EMAIL=
JARVIS_EMAIL_PASSWORD=
JARVIS_SMTP=smtp.gmail.com
JARVIS_SMTP_PORT=587
JARVIS_IMAP=imap.gmail.com

# ESP32 (Optional)
ESP32_PORT=COM3
MQTT_BROKER=localhost
MQTT_PORT=1883

# Spotify (Optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# News API (Optional)
NEWS_API_KEY=

# Server
JARVIS_PORT=8765
JARVIS_API_TOKEN=
